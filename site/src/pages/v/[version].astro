---
import Base from '../../layouts/Base.astro';
import { loadVersions, parseDiff } from '../../data/versions';
import { marked } from 'marked';

export function getStaticPaths() {
  return loadVersions().map((v) => ({ params: { version: v.version }, props: { v } }));
}

const { v } = Astro.props;
const s = v.signature;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const diffSections = v.diff ? parseDiff(v.diff) : [];

function stripFront(text: string): string {
  const i = text.search(/^## (API request|New telemetry|New features|Security)/m);
  return i >= 0 ? text.slice(i) : text;
}

let analysisHtml = '';
if (v.analysis) {
  analysisHtml = await marked.parse(stripFront(v.analysis), { breaks: false });
}

const stats = [
  { n: s.betaFlags?.length ?? 0, label: 'Beta Flags' },
  { n: s.featureFlags?.length ?? 0, label: 'Feature Flags' },
  { n: s.envVars?.length ?? 0, label: 'Env Vars' },
  { n: s.telemetryEvents?.length ?? 0, label: 'Telemetry' },
  { n: s.modelIds?.length ?? 0, label: 'Models' },
  { n: s.apiEndpoints?.length ?? 0, label: 'Endpoints' },
  { n: s.headerKeys?.length ?? 0, label: 'Headers' },
  { n: s.oauthScopes?.length ?? 0, label: 'OAuth' },
];
---

<Base title={`v${v.version} — The Claude Code Monitor`}>
  <nav class="crumb"><a href={`${base}/`}>← All versions</a></nav>

  <header class="vhead">
    <time>{v.date}</time>
    <h1>v{v.version}</h1>
    <div class="sgrid">
      {stats.map(({ n, label }) => (
        <div class="si">
          <span class="sn">{n}</span>
          <span class="sl">{label}</span>
        </div>
      ))}
    </div>
  </header>

  {diffSections.length > 0 && (
    <section class="card diff">
      <h2>Changes from v{v.prevVersion}</h2>
      {diffSections.map(({ category, added, removed }) => (
        <div class="dcat">
          <h3>{category}</h3>
          <div class="ditems">
            {added.map((a) => <span class="di da">+ {a}</span>)}
            {removed.map((r) => <span class="di dr">- {r}</span>)}
          </div>
        </div>
      ))}
    </section>
  )}

  {analysisHtml && (
    <section class="card">
      <h2>AI Analysis</h2>
      <article class="prose" set:html={analysisHtml} />
    </section>
  )}

  <section class="card">
    <h2>Signature Data</h2>
    <details>
      <summary>Beta Flags ({s.betaFlags?.length})</summary>
      <div class="tgrid">{(s.betaFlags || []).map((b: any) => <code>{b.value}</code>)}</div>
    </details>
    <details>
      <summary>Model IDs ({s.modelIds?.length})</summary>
      <div class="tgrid">{(s.modelIds || []).map((m: string) => <code>{m}</code>)}</div>
    </details>
    <details>
      <summary>API Endpoints ({s.apiEndpoints?.length})</summary>
      <div class="tgrid">{(s.apiEndpoints || []).map((e: string) => <code>{e}</code>)}</div>
    </details>
    <details>
      <summary>HTTP Headers ({s.headerKeys?.length})</summary>
      <div class="tgrid">{(s.headerKeys || []).map((h: string) => <code>{h}</code>)}</div>
    </details>
    <details>
      <summary>OAuth Scopes ({s.oauthScopes?.length})</summary>
      <div class="tgrid">{(s.oauthScopes || []).map((o: string) => <code>{o}</code>)}</div>
    </details>
    <details>
      <summary>Environment Variables ({s.envVars?.length})</summary>
      <div class="tgrid sm">{(s.envVars || []).map((e: string) => <code>{e}</code>)}</div>
    </details>
  </section>

  <nav class="crumb"><a href={`${base}/`}>← Back to all versions</a></nav>
</Base>

<style is:global>
  /* VERSION DETAIL — all styles unscoped so set:html content gets them */
  .crumb { padding: 24px 0 0; font: 400 .78rem var(--sans); }

  .vhead {
    padding: 28px 0 24px;
    border-bottom: 1px solid var(--border-strong);
    margin-bottom: 28px;
  }
  .vhead time { font: 400 .72rem var(--mono); color: var(--text-dim); }
  .vhead h1 { font: 500 2rem/1.1 var(--serif); letter-spacing: -.02em; margin: 4px 0 16px; }

  .sgrid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  @media (max-width: 600px) { .sgrid { grid-template-columns: repeat(2, 1fr); } }
  .si {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 12px 14px;
  }
  .sn { display: block; font: 500 1.3rem var(--mono); color: var(--text); }
  .sl { font: 400 .65rem var(--sans); color: var(--text-dim); text-transform: uppercase; letter-spacing: .04em; }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 22px 26px 24px;
    margin-bottom: 24px;
  }
  .card > h2 {
    font: 500 1rem var(--serif);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  /* DIFF */
  .diff { background: var(--surface); }
  .dcat { margin-bottom: 14px; }
  .dcat h3 {
    font: 500 .65rem var(--mono);
    color: var(--accent);
    letter-spacing: .05em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .ditems { display: flex; flex-wrap: wrap; gap: 5px; }
  .di {
    font: 400 .72rem var(--mono);
    padding: 3px 10px;
    border-radius: 3px;
    border: 1px solid;
  }
  .da { color: var(--green); background: var(--green-bg); border-color: #d0e6d0; }
  .dr { color: var(--red); background: var(--red-bg); border-color: #e6d0d0; text-decoration: line-through; }

  /* PROSE — analysis markdown */
  .prose { font-size: .88rem; line-height: 1.7; color: var(--text); }
  .prose h1 { font: 500 1.05rem var(--serif); color: var(--text); margin: 32px 0 8px; padding-top: 20px; border-top: 1px solid var(--border); }
  .prose h2 { font: 500 .95rem var(--serif); color: var(--text); margin: 28px 0 8px; padding-top: 16px; border-top: 1px solid var(--border); }
  .prose h3 { font: 500 .8rem var(--sans); color: var(--accent); margin: 16px 0 6px; }
  .prose h4 { font: 500 .75rem var(--sans); color: var(--text-secondary); margin: 12px 0 4px; }
  .prose p { margin: 6px 0; }
  .prose ul, .prose ol { padding-left: 20px; margin: 6px 0; }
  .prose li { margin: 3px 0; }
  .prose strong { color: var(--text); font-weight: 500; }
  .prose hr { border: none; border-top: 1px solid var(--border); margin: 28px 0; }
  .prose table { border-collapse: collapse; width: 100%; margin: 12px 0; font-size: .82rem; }
  .prose th, .prose td { padding: 7px 12px; border: 1px solid var(--border); text-align: left; }
  .prose th, .prose thead td { font-weight: 500; background: var(--surface-dim); color: var(--text); }
  .prose blockquote { border-left: 3px solid var(--border); padding-left: 14px; color: var(--text-secondary); margin: 10px 0; }

  /* DETAILS / TAGS */
  details {
    border-top: 1px solid var(--border);
  }
  details:first-of-type { border-top: none; }
  summary {
    padding: 10px 0;
    font: 500 .78rem var(--mono);
    color: var(--text-secondary);
    cursor: pointer;
    user-select: none;
  }
  summary:hover { color: var(--text); }
  details[open] summary { color: var(--text); margin-bottom: 4px; }
  .tgrid { display: flex; flex-wrap: wrap; gap: 5px; padding-bottom: 10px; }
  .tgrid code { font-size: .7rem; padding: 2px 7px; white-space: nowrap; }
  .tgrid.sm code { font-size: .65rem; }
</style>
